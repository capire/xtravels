{
  "name": "@capire/xtravels",
  "version": "1.0.1",
  "description": "CAP XTravels sample application",
  "scripts": {
    "lint": "npx eslint .",
    "start": "cds-serve",
    "test": "cds test"
  },
  "dependencies": {
    "@cap-js/mcp": "*",
    "@capire/common": "*",
    "@capire/s4": "*",
    "@capire/xflights-data": "*",
    "@sap/cds": "^10"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1",
    "@cap-js/sqlite": "^3"
  },
  "cds": {
    "requires": {
      "FlightsService": true,
      "HotelsService": true,
      "EventsService": true
      "[production]": {
        "FlightsService": {
          "kind": "hcql",
          "credentials": {
            "destination": "flights-dest",
            "path": "/hcql/flights"
          }
        },
        "sap.capire.s4.business-partner": {
          "kind": "odata-v2",
          "credentials": {
            "destination": "s4-dest",
            "path": "/sap/opu/odata/sap/API_BUSINESS_PARTNER"
          }
        }
      }
    }
  },
  "license": "Apache-2.0"
}
