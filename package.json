{
  "name": "@capire/xtravels",
  "version": "1.0.1",
  "description": "CAP XTravels sample application",
  "scripts": {
    "lint": "npx eslint .",
    "start": "cds-serve",
    "test": "cds test"
  },
  "dependencies-for-agents": {
    "@cap-js/agents": "^0.1.0",
    "@cap-js/ai": "^1.0.1",
    "json ist doof": true
  },
  "dependencies": {
    "@cap-js/mcp": "*",
    "@capire/common": "*",
    "@capire/s4": "*",
    "@capire/xflights-data": "*",
    "@sap/cds": "^10"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1",
    "@cap-js/sqlite": "^3"
  },
  "cds": {
    "-agents": {
      "contentFilter": false,
      "pool": false
    },
    "-requires": {
      "FlightsService": {
        "kind": "rest",
        "credentials": { "url": "http://localhost:4005/mcp/data" }
      },
      "HotelsService": {
        "kind": "rest",
        "credentials": { "url": "http://localhost:4006/a2a/hotel" }
      },
      "EventService": {
        "kind": "rest",
        "credentials": { "url": "http://localhost:4006/a2a/event" }
      },
      "TravelAgentService": {
        "mcpServers": [
          "FlightsService"
        ],
        "subAgents": [
           "HotelsService",
           "EventService"
        ]
      }
    }
  },
  "license": "Apache-2.0"
}
