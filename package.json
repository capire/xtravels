{
  "name": "@capire/xtravels",
  "version": "1.0.1",
  "description": "CAP XTravels sample application",
  "scripts": {
    "start": "cds watch --port 4004",
    "reset": "cds deploy && cds watch --port 4004",
    "lint": "npx eslint .",
    "test": "cds test"
  },
  "dependencies": {
    "@capire/common": "*",
    "@capire/s4": "*",
    "@capire/xflights-data": "*",
    "@sap/cds": "^10"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1",
    "@cap-js/sqlite": "^3"
  },
  "cds": {
    "requires": {
      "messaging": {
        "kind": "file-based-messaging",
        "file": "../msg-box",
        "inboxed": true
      },
      "queue": {
        "maxAttempts": 6
      }
    },
    "log": {
      "levels": {
        "odata": "error",
        "cds": "debug"
      }
    }
  },
  "license": "Apache-2.0"
}
